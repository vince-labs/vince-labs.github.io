</footer>

<script>
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 40);
});

window.scrollTo = function(id) {
  document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
};

const heroTitle = document.getElementById('hero-title');
const titleText = 'vince';
const italicText = 'labs';

titleText.split('').forEach((letter, i) => {
  const span = document.createElement('span');
  span.textContent = letter;
  span.style.cssText = `display:inline-block;animation:fadeUp .6s ${i * 0.045}s ease forwards;opacity:0`;
  heroTitle.appendChild(span);
});

const italic = document.createElement('span');
italic.className = 'hero-title-italic';
italicText.split('').forEach((letter, i) => {
  const span = document.createElement('span');
  span.textContent = letter;
  span.style.cssText = `display:inline-block;animation:fadeUp .6s ${(i + titleText.length) * 0.045 + 0.1}s ease forwards;opacity:0`;
  italic.appendChild(span);
});
heroTitle.appendChild(italic);

const svg = document.getElementById('paths-svg');

function genPaths(positionMult) {
  for (let i = 0; i < 28; i++) {
    const p = positionMult;
    const d = `M-${380 - i*5*p} -${189 + i*6}C-${380 - i*5*p} -${189 + i*6} -${312 - i*5*p} ${216 - i*6} ${152 - i*5*p} ${343 - i*6}C${616 - i*5*p} ${470 - i*6} ${684 - i*5*p} ${875 - i*6} ${684 - i*5*p} ${875 - i*6}`;
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', d);
    path.setAttribute('stroke', '#1d1d1f');
    path.setAttribute('stroke-width', (0.4 + i * 0.025).toString());
    path.setAttribute('stroke-linecap', 'round');
    path.setAttribute('fill', 'none');
    const dur = 18 + i * 0.7 + Math.random() * 4;
    const delay = i * 0.6;
    path.style.cssText = `stroke-dasharray:3000;stroke-dashoffset:3000;animation:drawPath ${dur}s ${delay}s linear infinite`;
    svg.appendChild(path);
  }
}

genPaths(1);
genPaths(-1);
</script>
</body>
</html>