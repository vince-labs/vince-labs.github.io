<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>vince-labs — AI Specialist</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Figtree',sans-serif;background:#fff;color:#1d1d1f;overflow-x:hidden;line-height:1}

@keyframes drawPath{
  0%{stroke-dashoffset:3000;opacity:0}
  15%{opacity:1}
  85%{opacity:.5}
  100%{stroke-dashoffset:-3000;opacity:0}
}
@keyframes fadeUp{
  from{opacity:0;transform:translateY(28px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes floatY{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-7px)}}
@keyframes pulse{0%,100%{opacity:.4}50%{opacity:1}}

.container{max-width:1080px;margin:0 auto;padding:0 28px}

nav{
  position:fixed;top:0;left:0;right:0;z-index:999;
  height:52px;display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;
  transition:background .3s, backdrop-filter .3s, border-bottom .3s;
}
nav.scrolled{
  background:rgba(255,255,255,.82);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid rgba(0,0,0,.08);
}
.nav-logo{font-size:17px;font-weight:900;letter-spacing:-.03em;cursor:pointer;color:#1d1d1f}
.nav-links{display:flex;gap:2px}
.nav-link{
  font-size:13.5px;font-weight:500;color:#1d1d1f;
  padding:6px 13px;border-radius:20px;cursor:pointer;
  transition:background .15s;text-decoration:none;
}
.nav-link:hover{background:rgba(0,0,0,.06)}

/* HERO */
#home{
  position:relative;min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}
.paths-container{position:absolute;inset:0;overflow:hidden}
.paths-container svg{width:100%;height:100%;position:absolute;inset:0}
.hero-gradient{
  position:absolute;inset:0;
  background:radial-gradient(ellipse 90% 70% at 50% 50%, rgba(255,255,255,0) 20%, rgba(255,255,255,.75) 100%);
  pointer-events:none;
}
.hero-content{position:relative;z-index:2;text-align:center;padding:0 24px}
.hero-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(0,0,0,.045);border:1px solid rgba(0,0,0,.08);
  border-radius:980px;padding:7px 16px;margin-bottom:36px;
  animation:fadeIn 1s .1s ease forwards;opacity:0;
}
.hero-badge-dot{width:6px;height:6px;border-radius:50%;background:#34c759;animation:pulse 2s infinite}
.hero-badge span{font-size:13px;font-weight:500;color:#6e6e73}
.hero-title{
  font-size:clamp(72px,15vw,148px);
  font-weight:900;letter-spacing:-.05em;line-height:.92;
  color:#1d1d1f;margin-bottom:4px;
}
.hero-title-italic{
  font-family:'Instrument Serif',serif;
  font-style:italic;font-weight:400;
  color:#6e6e73;font-size:clamp(56px,12vw,118px);
  display:block;letter-spacing:-.03em;
}
.hero-sub{
  font-size:clamp(17px,2.2vw,22px);color:#6e6e73;
  font-weight:400;max-width:480px;margin:28px auto 44px;
  line-height:1.55;
  animation:fadeUp .9s .5s ease forwards;opacity:0;
}
.hero-actions{
  display:flex;gap:12px;justify-content:center;flex-wrap:wrap;
  animation:fadeUp .9s .7s ease forwards;opacity:0;
}
.btn-primary{
  background:#1d1d1f;color:#fff;border:none;
  border-radius:980px;padding:13px 30px;
  font-family:'Figtree',sans-serif;font-size:15px;font-weight:600;
  cursor:pointer;transition:background .2s,transform .15s;
}
.btn-primary:hover{background:#3a3a3c;transform:scale(1.02)}
.btn-outline{
  background:transparent;color:#1d1d1f;border:1.5px solid rgba(0,0,0,.2);
  border-radius:980px;padding:13px 30px;
  font-family:'Figtree',sans-serif;font-size:15px;font-weight:600;
  cursor:pointer;transition:all .2s;
}
.btn-outline:hover{background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.35)}
.scroll-cue{
  position:absolute;bottom:32px;left:50%;
  transform:translateX(-50%);cursor:pointer;
  animation:floatY 2.4s ease-in-out infinite;
}

/* ABOUT */
#about{padding:110px 0;background:#f5f5f7}
.section-eyebrow{
  font-size:12px;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;color:#6e6e73;margin-bottom:14px;
}
.section-h2{
  font-size:clamp(30px,4.5vw,52px);font-weight:800;
  letter-spacing:-.035em;line-height:1.08;
  color:#1d1d1f;margin-bottom:20px;
}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-text p{font-size:16.5px;color:#6e6e73;line-height:1.72;margin-bottom:18px;font-weight:400}
.about-text p b{color:#1d1d1f}
.stats{display:flex;gap:32px;margin-top:32px;flex-wrap:wrap}
.stat-num{font-size:40px;font-weight:900;letter-spacing:-.04em;color:#1d1d1f;line-height:1}
.stat-label{font-size:13px;color:#6e6e73;font-weight:500;margin-top:4px}
.mini-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.mini-card{
  background:#fff;border-radius:18px;padding:22px 20px;
  border:1px solid rgba(0,0,0,.06);
  transition:transform .25s,box-shadow .25s;
}
.mini-card:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,0,0,.07)}
.mini-card-icon{margin-bottom:12px;color:#1d1d1f}
.mini-card h4{font-size:14.5px;font-weight:700;color:#1d1d1f;margin-bottom:5px;letter-spacing:-.01em}
.mini-card p{font-size:12.5px;color:#6e6e73;line-height:1.5}

/* SKILLS */
#skills{padding:110px 0;background:#fff}
.skills-header{margin-bottom:56px}
.section-desc{font-size:17px;color:#6e6e73;max-width:500px;line-height:1.6;font-weight:400}
.skills-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.skill-pill{
  background:#f5f5f7;border-radius:16px;padding:22px 18px;
  text-align:center;transition:transform .25s,background .2s;
  cursor:default;
}
.skill-pill:hover{transform:translateY(-4px);background:#ebebee}
.skill-pill-icon{margin-bottom:10px;display:flex;justify-content:center;align-items:center}
.skill-pill-name{font-size:14.5px;font-weight:700;color:#1d1d1f;margin-bottom:6px;letter-spacing:-.01em}
.skill-tag{
  display:inline-block;background:#e8e8ed;color:#6e6e73;
  font-size:11.5px;font-weight:600;padding:3px 10px;border-radius:980px;
}

/* PROJECTS */
#projects{padding:110px 0;background:#f5f5f7}
.projects-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.proj-card{
  background:#fff;border:1px solid rgba(0,0,0,.07);
  border-radius:24px;padding:30px;
  transition:transform .3s,box-shadow .3s;cursor:default;
}
.proj-card:hover{transform:translateY(-5px);box-shadow:0 24px 60px rgba(0,0,0,.09)}
.proj-card.dark{background:#1d1d1f;border-color:transparent}
.proj-card.dark:hover{box-shadow:0 24px 60px rgba(0,0,0,.3)}
.proj-icon{margin-bottom:18px}
.proj-title{font-size:20px;font-weight:800;letter-spacing:-.03em;color:#1d1d1f;margin-bottom:10px}
.proj-card.dark .proj-title{color:#fff}
.proj-desc{font-size:14.5px;color:#6e6e73;line-height:1.65;margin-bottom:20px}
.proj-card.dark .proj-desc{color:rgba(255,255,255,.55)}
.proj-tags{display:flex;gap:8px;flex-wrap:wrap}
.proj-tag{
  background:#f5f5f7;color:#6e6e73;
  font-size:12px;font-weight:600;padding:4px 12px;border-radius:980px;
}
.proj-card.dark .proj-tag{background:rgba(255,255,255,.1);color:rgba(255,255,255,.7)}

/* CONTACT */
#contact{padding:120px 0;background:#fff;text-align:center}
#contact .section-h2{margin:0 auto 20px}
#contact .section-desc{margin:0 auto 52px;max-width:440px}
.contact-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
footer{background:#f5f5f7;padding:32px;text-align:center;font-size:13.5px;color:#6e6e73;font-weight:500}

@media(max-width:768px){
  .about-grid{grid-template-columns:1fr}
  .skills-grid{grid-template-columns:repeat(2,1fr)}
  .projects-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<nav id="nav">
  <div class="nav-logo" onclick="scrollTo('home')">vince-labs</div>
  <div class="nav-links">
    <a class="nav-link" onclick="scrollTo('about')">About</a>
    <a class="nav-link" onclick="scrollTo('skills')">Skills</a>
