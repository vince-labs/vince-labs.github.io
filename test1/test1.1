<!-- CONTACT -->
<section id="contact">
  <div class="container">
    <p class="section-eyebrow">Contact</p>
    <h2 class="section-h2">Let's build<br/>something together.</h2>
    <p class="section-desc">Have a project in mind, or just want to talk AI? I'm always open to new ideas and collaborations.</p>
